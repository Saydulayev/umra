/* ХАДЖ - Шаг 1: 8-е зу-ль-хиджжа */
"hajj_step1_title" = "الثامن من ذي الحجة — يوم التروية";

"hajj_step1_ihram_title" = "الدخول في حالة الإحرام";
"hajj_step1_ihram_text" = "ادخلوا في حالة الإحرام في مكان الإقامة بعد الفجر وقبل الظهر.

انووا أداء الحج وقولوا:";

"hajj_step1_ihram_arabic" = "لَبَّيْكَ اللَّهُمَّ بِحَجٍّ";
"hajj_step1_ihram_transliteration" = "";
"hajj_step1_ihram_translation" = "

استقبلوا القبلة وقولوا:";

"hajj_step1_ihram_dua_arabic" = "اللَّهُمَّ هَذِهِ حِجَّةٌ لَا رِيَاءَ فِيهَا وَلَا سُمْعَةَ";
"hajj_step1_ihram_dua_transliteration" = "";
"hajj_step1_ihram_dua_translation" = "";

"hajj_step1_talbiyah_title" = "التلبية";
"hajj_step1_talbiyah_text" = "ابدؤوا بالجهر بالتلبية وداوموا على تكرارها حتى رمي الجمار عند الجمرة الكبرى (في اليوم العاشر من ذي الحجة):";

"hajj_step1_talbiyah_arabic" = "لَبَّيْكَ اللَّهُمَّ لَبَّيْكَ، لَبَّيْكَ لاَ شَرِيكَ لَكَ لَبَّيْكَ، إِنَّ الْحَمْدَ، وَالنِّعْمَةَ، لَكَ وَالْمُلْكَ، لاَ شَرِيكَ لَكَ";
"hajj_step1_talbiyah_transliteration" = "";
"hajj_step1_talbiyah_translation" = "";

"hajj_step1_mina_title" = "التوجّه إلى وادي منى";
"hajj_step1_mina_text" = "ثم توجّهوا بهدوء إلى وادي منى، وأدّوا فيه:
• صلاة الظهر،
• صلاة العصر،
• صلاة المغرب،
• صلاة العشاء،

مع القصر دون الجمع.

وباتوا ليلتكم في وادي منى.";

/* ХАДЖ - Шаг 2: 9-е зу-ль-хиджжа */
"hajj_step2_title" = "التاسع من ذي الحجة — يوم الوقوف بعرفة";

"hajj_step2_arafat_title" = "التوجّه إلى وادي عرفة";
"hajj_step2_arafat_text" = "أدّوا صلاة الفجر في وادي منى، وبعد شروق الشمس توجّهوا إلى وادي عرفة. وداوموا على التلبية والتكبير (قول «الله أكبر»).

وعند الاستطاعة، توقّفوا في موضع نمِرَة القريب من عرفة وامكثوا فيه إلى الزوال، ثم توجّهوا إلى وادي عُرَنَة (قبل عرفة).

استمعوا إلى خطبة الإمام، ثم إذا دخل وقت الظهر صلّوا معه صلاتي الظهر والعصر جمعًا وقصرًا. ويُؤذَّن لهما أذان واحد، وتُقام لكل صلاة إقامة. ولا تُصلَّى بين الصلاتين نوافل.";

"hajj_step2_standing_title" = "الوقوف بعرفة";
"hajj_step2_standing_text" = "ثم توجّهوا إلى عرفة وامكثوا فيها إلى غروب الشمس. وعند الاستطاعة، قفوا قرب الحجارة الكبيرة المنتشرة عند سفح جبل الرحمة (جبل الرحمة). وإن لم يتيسّر ذلك، فإنّ كل وادي عرفة موضع للوقوف.

ويُستحب الوقوف مستقبلين القبلة، رافعين الأيدي، متضرّعين إلى الله بالدعاء، مع الإكثار من التلبية.

كما يُستحب جدًا الإكثار من الدعاء التالي:";

"hajj_step2_dua_arabic" = "لَا إِلٰهَ إِلَّا اللهُ وَحْدَهُ لَا شَرِيكَ لَهُ لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ";
"hajj_step2_dua_transliteration" = "";
"hajj_step2_dua_translation" = "";

"hajj_step2_muzdalifah_title" = "الانطلاق من عرفة إلى مزدلفة";
"hajj_step2_muzdalifah_text" = "بعد غروب الشمس، انطلقوا من عرفة إلى مزدلفة بسكينة وهدوء.";

"hajj_step2_night_title" = "المبيت في مزدلفة";
"hajj_step2_night_text" = "عند الوصول إلى مزدلفة، صلّوا صلاتي المغرب والعشاء جمعًا وقصرًا. يُؤذَّن أذانًا واحدًا، ثم تُقام الصلاة ويُصلَّى المغرب ثلاث ركعات، ثم تُقام صلاة العشاء وتُصلَّى ركعتين قصرًا. ولا تُصلَّى بين الصلاتين نوافل. ثم ناموا حتى الفجر.";

/* ХАДЖ - Шаг 3: 10-е зу-ль-хиджжа */
"hajj_step3_title" = "10 ذو الحجة — يوم النحر";

"hajj_step3_fajr_title" = "الفجر";
"hajj_step3_fajr_text" = "أدّوا صلاة الفجر في مزدلفة في أول وقتها المخصّص لها.";

"hajj_step3_mashaar_title" = "التوجّه إلى المشعر الحرام";
"hajj_step3_mashaar_text" = "ثم توجّهوا إلى المشعر الحرام (وهو جبل يقع في مزدلفة)، واصعدوا إليه واستقبلوا القبلة. أكثروا من حمد الله («الحمد لله»)، وتعظيمه («الله أكبر»)، وتوحيده («لا إله إلا الله»)، وادعوا الله حتى يشتدّ الضوء.

وإن لم يتيسّر الوصول إلى المشعر الحرام، فيجوز فعل ذلك في أي موضع من وادي مزدلفة.";

"hajj_step3_mina_title" = "التوجّه إلى وادي منى";
"hajj_step3_mina_text" = "ثم قبل شروق الشمس انطلقوا من مزدلفة إلى منى بسكينة وهدوء.";

"hajj_step3_jamarat_title" = "رمي الجمار عند الجمرة الكبرى";
"hajj_step3_jamarat_text" = "عند الوصول إلى وادي منى، اجمعوا سبع حصيات بحجم أكبر قليلًا من حبة البازلاء لرمي الجمرة الكبرى. ويُستحب أداء هذا النسك قبل الزوال، فإن لم يتيسّر فإلى الليل.

استقبلوا الجمرة الكبرى، واجعلوا مكة عن يساركم ومنى عن يمينكم.

ارموا الحصى واحدة تلو الأخرى، ومع كل حصاة قولوا: «الله أكبر».";

"hajj_step3_partial_exit_title" = "التحلل الأول من الإحرام";
"hajj_step3_partial_exit_text" = "بعد رمي آخر حصاة، اقطعوا التلبية، وارجعوا إلى مكان إقامتكم في منى، وارتدوا الملابس المعتادة، وتطيّبوا. وبعد رمي الجمرة الكبرى تزول جميع محظورات الإحرام إلا الجماع.";

"hajj_step3_sacrifice_title" = "الذبح";
"hajj_step3_sacrifice_text" = "إذا كنتم قد اشتريتم شهادة الأضحية، فذلك جائز. وإن لم تفعلوا، فتوجّهوا إلى المسلخ وقوموا بالذبح.";

"hajj_step3_shaving_title" = "حلق الرأس";
"hajj_step3_shaving_text" = "بعد الذبح، يحلق الرجل شعر رأسه (وهو الأفضل)، أو يقصّره بالتساوي (وهو أقل فضلًا)، أمّا المرأة فتقصّ خصلة من شعرها بمقدار ثلث الإصبع.";

"hajj_step3_tawaf_title" = "طواف الإفاضة";
"hajj_step3_tawaf_text" = "ثم توجّهوا إلى مكة لأداء طواف الإفاضة. ولا يلزم لبس لباس الإحرام.

وعند دخول المسجد الحرام، افعلوا كما فعلتم في العمرة: دعاء دخول المسجد، الطواف سبعة أشواط، ركعتان بعد الطواف، شرب ماء زمزم، السعي بين الصفا والمروة سبعة أشواط، ودعاء الخروج من المسجد.

تنبيه: يُؤدّى هذا الطواف مشيًا عاديًا من أوله إلى آخره.";

"hajj_step3_attention_title" = "تنبيه لمن لم يتمكّن من طواف الإفاضة يوم 10 ذو الحجة";
"hajj_step3_attention_text" = "من لم يتمكّن من أداء طواف الإفاضة قبل مساء يوم 10 ذو الحجة، فعليه أن يعود إلى حالة الإحرام التي كان عليها قبل رمي الجمار: فيخلع ملابسه المعتادة، ويلبس لباس الإحرام، ويبقى مُحرِمًا حتى يؤدي طواف الإفاضة. وقد قال النبي ﷺ:

«فَإِنْ أَمْسَيْتَ قَبْلَ أَنْ تَطُوفَ بِهَذَا الْبَيْتِ، رَجَعْتَ كَمَا كُنْتَ، حَتَّى تَطُوفَ بِالْبَيْتِ»
[أبو داود. السنن. № 1999; ابن خزيمة. الصحيح. № 2958; الحاكم. المستدرك. № 1800; البيهقي. السنن الكبرى. № 9601].";

"hajj_step3_full_exit_title" = "التحلل الكامل من الإحرام";
"hajj_step3_full_exit_text" = "بعد الانتهاء من السعي بين الصفا والمروة، يتحلل الحاج تحللًا كاملًا، وتزول عنه جميع محظورات الإحرام، بما فيها الجماع.";

"hajj_step3_return_title" = "العودة إلى وادي منى";
"hajj_step3_return_text" = "بعد إتمام طواف الإفاضة، ارجعوا إلى مكان إقامتكم في وادي منى.";

/* ХАДЖ - Шаг 4: 11, 12 и 13-е зу-ль-хиджжа */
"hajj_step4_title" = "11 و12 و13 ذو الحجة — أيام التشريق";

"hajj_step4_stay_title" = "المكوث في منى";
"hajj_step4_stay_text" = "خلال ثلاثة أيام (أيام التشريق) باتوا في مكان إقامتكم بمنى.";

"hajj_step4_jamarat_title" = "رمي الجمار الثلاث";
"hajj_step4_jamarat_text" = "يبدأ وقت أداء هذا النسك بعد الزوال ويستمر إلى دخول الليل. في كل يوم اجمعوا واحدًا وعشرين حصاة بحجم أكبر قليلًا من حبة البازلاء لرمي الجمار الثلاث (سبع لكل جمرة).

توجّهوا لرمي الحصيات عند الجمرة الصغرى بسكينة. استقبلوا الجمرة الصغرى واجعلوا مكة عن يساركم ومنى عن يمينكم.

ارموا الحصيات على الجمرة الصغرى واحدة تلو الأخرى، ومع كل حصاة قولوا: «الله أكبر». وبعد الانتهاء من رمي الجمرة الأولى، استقبلوا القبلة، وارفعوا أيديكم، وادعوا بما شئتم.

ثم توجّهوا لرمي الحصيات عند الجمرة الوسطى بسكينة. استقبلوا الجمرة الوسطى واجعلوا مكة عن يساركم ومنى عن يمينكم.

ارموا الحصيات على الجمرة الوسطى واحدة تلو الأخرى، ومع كل حصاة قولوا: «الله أكبر». وبعد الانتهاء من رمي الجمرة الثانية، استقبلوا القبلة، وارفعوا أيديكم، وادعوا بما شئتم.

ثم توجّهوا لرمي الحصيات عند الجمرة الكبرى بسكينة. استقبلوا الجمرة الكبرى واجعلوا مكة عن يساركم ومنى عن يمينكم.

ارموا الحصيات على الجمرة الكبرى واحدة تلو الأخرى، ومع كل حصاة قولوا: «الله أكبر». وبعد الانتهاء من رمي الجمرة الثالثة والأخيرة، انصرفوا دون الوقوف للدعاء كما في المرتين السابقتين.

يُؤدّى هذا النسك في الأيام الثلاثة من أيام التشريق. وبعد الانتهاء من رمي الجمار في يوم 13 ذو الحجة، ارجعوا إلى مكة.";

/* ХАДЖ - Шаг 5: Прощальный обход */
"hajj_step5_title" = "طواف الوداع";

"hajj_step5_farewell_text" = "قبل العودة إلى الديار، يجب أداء طواف الوداع حول الكعبة. ولا يلزم لبس لباس الإحرام.

وعند دخول المسجد الحرام، افعلوا كما فعلتم في العمرة: دعاء دخول المسجد، الطواف سبعة أشواط حول الكعبة (الطواف)، ودعاء الخروج من المسجد.

تنبيه: يُؤدّى هذا الطواف مشيًا عاديًا من أوله إلى آخره. ولا يُؤدّى السعي بين الصفا والمروة.


تقبّل الله منكم حجّكم!";


