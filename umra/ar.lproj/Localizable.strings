/* --- ПОЯСНЕНИЕ --- */
"Umrah for parents explanation" = "إذا أردت أداء العمرة عن والديك أو عن شخص آخر، فبدل التلبية المعتادة انطق بإحدى الصيغ المذكورة، مع إضافة الاسم بعد كلمة «أبي» (الأب)، أو «أمي» (الأم)، أو بعد كلمة «عن» فقط اسم الشخص الذي تُؤدَّى العمرة عنه. وبعد التلفظ بالنية والتلبية مع ذكر الاسم، تُؤدَّى جميع المناسك الأخرى، والأدعية (الدعاء)، وذكر الله (الذكر) كالمعتاد، كما لو كنت تؤدي العمرة عن نفسك. والفرق الوحيد هو النية.";



/* KAABA */
"Kaaba text1" = "
الطواف حول الكعبة";
"Kaaba text2" = "
ابدأ الطواف حول الكعبة سبعة أشواط (الطواف).
منذ بداية هذا الطواف وحتى انتهائه، يكشف الرجال عن الكتف الأيمن.
        
بعد ذلك يلمس الحاج الحجر الأسود بيده ويقبّله.
        
فإن لم يتمكن من تقبيل الحجر الأسود، فليلمسه بيده.
        
فإن لم يتمكن من اللمس ولا من التقبيل، فليتوجّه إليه بوجهه، ويشير إليه بيده اليمنى، ويقول التكبير: «الله أكبر». (ويُفعل ذلك في كل شوط من أشواط الطواف.)
";
"Kaaba text3" = "ابدأ الطواف حول الكعبة سبعة أشواط (الطواف) من الحجر الأسود.
يُحسب المرور من الحجر الأسود إلى الحجر الأسود شوطًا واحدًا. وعند بدء شوط جديد، أشر بيدك اليمنى إلى الحجر الأسود وقل التكبير. في الأشواط الثلاثة الأولى، من الحجر الأسود إلى الحجر الأسود، يُسنّ للرجال أن يمشوا مشيًا سريعًا، أما الأشواط الأربعة المتبقية فبمشية عادية. وعند الإمكان، يُستحب لمس الركن اليماني في كل شوط. وكلما مررت بين الركن اليماني والحجر الأسود فقل:
";
"Kaaba text4" = "
سورة «البقرة»، الآية 201.";
"Prayer after Tawaf of Kaaba." = "الصلاة بعد الطواف حول الكعبة.";


/* Namaz after Tawaf around the Kaaba. */
"Prayer after Tawaf of Kaaba." = "
الصلاة بعد الطواف حول الكعبة.";

"Having completed seven circuits around the Kaaba" = "
بعد إتمام الطواف سبعة أشواط حول الكعبة، يُغطي الرجل كتفه الأيمن. ثم توجّهوا إلى مقام إبراهيم وقولوا:
";

"Place of standing of Ibrahim" = "
(سورة 2 «البقرة»، الآية 125).
    
وعند الاستطاعة، خلف مقام إبراهيم، أو في أي موضع من المسجد الحرام، صلّوا ركعتين. ولا تنسوا اتخاذ سترة أمامكم بحيث لا يمر أحد بينكم وبينها. في الركعة الأولى بعد سورة 1 «الفاتحة» اقرأوا سورة 109 «الكافرون»، وفي الركعة الثانية بعد سورة «الفاتحة» اقرأوا سورة 112 «الإخلاص».

وبعد الانتهاء من الصلاة، توجّهوا إلى موضع ماء زمزم.";

/* Drinking Zamzam water. */
"Drinking Zamzam water." = "
شرب ماء زمزم.";
"Zamzam text" = "
اشرب من ماء زمزم وصبّ منه على رأسك.
    
عن جابر رضي الله عنه قال: «أتى النبي ﷺ زمزم فشرب منها وصبّ على رأسه».
أحمد (3/394)، ابن خزيمة (4/305).
    
وعن جابر رضي الله عنه أن رسول الله ﷺ قال:
«ماء زمزم لما شُرِبَ له».
أحمد (3/357)، ابن ماجه (3062)، الحاكم (1739).
    
قال الشوكاني رحمه الله:
«وفي الحديث دليل على أن شرب ماء زمزم ينفع الشارب بأي نية شربه بها، من أمور الدنيا أو الآخرة، لأن قوله: (لِما شُرِبَ له) لفظ عام».
    
وقال النووي رحمه الله:
«ومعنى الحديث أن من شربه لشيء ناله، وقد جربه العلماء والصالحون لحاجات من أمور الدنيا والآخرة فنالوها بفضل الله تعالى».
";

/* Return to the Black Stone. */
"Return to the Black Stone." = "
العودة إلى الحجر الأسود.";
"Return to the Black Stone, recite the Takbir." = "
ارجعوا إلى الحجر الأسود، وكبّروا والمسوه كما سبق بيانه، أو أشاروا إليه باليد وكبّروا. الله أكبر.";
"Allah is great." = "

";

/* Safa and Marwa */
"Safa and Marwa" = "
الصفا والمروة";
"Head towards the hill of Safa" = "
توجّهوا إلى جبل الصفا لأداء السعي سبعة أشواط بين الصفا والمروة (السعي). وابدؤوا السعي من جبل الصفا.
    
    
وعند الاقتراب من الصفا اقرأوا:
";
"Surah Al-Baqarah, verse 158." = "
(سورة «البقرة»، الآية 158)
    
    ثم قولوا:
";
"We begin with that string" = "
    
اصعدوا على جبل الصفا، واستقبلوا الكعبة، وقولوا:
";
"Remembrance of Allah during the Sa'i of Safa and Marwa." = "
    
قولوا هذه الكلمات ثلاث مرات، وارفعوا أيديكم للدعاء بعد المرة الأولى والثانية. ثم ابدؤوا السعي من جبل الصفا إلى جبل المروة. ويُحسب الذهاب من الصفا إلى المروة شوطًا واحدًا، والرجوع شوطًا ثانيًا. وعند جبل المروة كرروا الترتيب نفسه: ذكر — دعاء — ذكر — دعاء — ذكر. وتُكرر هذه الأذكار والأدعية عند كل صعود إلى الصفا والمروة، ما عدا الشوط السابع. وعند الوصول إلى العلامة الأولى الملوّنة باللون الأخضر، يجب على الرجال الإسراع بالجري إلى العلامة الثانية، وما تبقّى من المسافة يُمشى فيه مشيًا عاديًا.
    
وأثناء السعي يمكن التوجّه إلى الله بهذه الدعاء:
";
"Du'a during the Sa'i ritual of Safa and Marwa." = "
    
لا حرج في ذلك، لأن هذه الدعاء ثابتة عن جماعة من السلف الصالحين.

وبعد إتمام الشوط السابع، لا يذكر الحاج ذكرًا ولا دعاءً على جبل المروة. وهذا يعني أن السعي قد اكتمل.

دعاء الخروج من المسجد الحرام. وبعد إتمام الشوط السابع على جبل المروة، اخرجوا من المسجد الحرام بالرجل اليسرى قائلين:
";
"Du'a upon exiting the Sacred Mosque." = "";

/* Shaving of the head or trimming of the hair. */
"Shaving the head string" = "
حلق الرأس أو تقصير الشعر.";
"Men shorten or shave their hair." = "
ثم يقوم الرجل بتقصير شعر رأسه كله بالتساوي أو بحلقه، أما المرأة فتقصّ خصلة من شعرها بطول قدر أنملة.

ملاحظة:
من قدم لأداء الحج فالأفضل له تقصير الشعر إذا كان لا يتوقع أن ينمو شعره بعد العمرة إلى وقت الحج، لأن الحلق يكون في الحج.
وأما من قدم لأداء العمرة فقط (دون حج) فالأفضل له حلق الرأس.
    
التحلل الكامل من الإحرام.
وبهذا تنتهي العمرة. ويخلع الرجل لباس الإحرام، وتزول جميع المحظورات التي كانت سارية في حال الإحرام.";
"Du'a at the end." = "
                        
وفي الختام أسأل اللهَ تعالى أن يتقبّل منا جميع أعمالنا الصالحة، وأن يُبقي لنا أجرها إلى ذلك اليوم الذي نلقاه فيه،
«يَوْمَ لَا يَنفَعُ مَالٌ وَلَا بَنُونَ ۝ إِلَّا مَنْ أَتَى ٱللَّهَ بِقَلْبٍ سَلِيمٍ»
(سورة «الشعراء»، الآيتان 88–89).

كما أسأل اللهَ تعالى أن يمنح الأجر الكامل لكل من ساهم في إنشاء هذا التطبيق وتطويره ونشره — بالمشورة أو بالعلم أو بالمال أو بالكلمة الطيبة — عن كل عمرة أُدِّيت بسببه.
كما قال رسولُ الله ﷺ:
«مَنْ دَلَّ عَلَى خَيْرٍ فَلَهُ مِثْلُ أَجْرِ فَاعِلِهِ»
(صحيح مسلم، رقم 1893).

والحمدُ للهِ ربِّ العالمين!";




