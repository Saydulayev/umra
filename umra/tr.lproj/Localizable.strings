"hajj_step1_ihram_dua_transliteration" = "Allahumma hazihi hijja la riyā’a fī-hā wa la sum‘ah";
"hajj_step1_ihram_dua_translation" = "Ey Allah’ım, bu hacda gösteriş ve şöhret arzusu yoktur!";

"hajj_step1_talbiyah_title" = "Telbiye";
"hajj_step1_talbiyah_text" = "Telbiyeyi yüksek sesle söylemeye başlayın ve Büyük Cemre’ye (10 Zilhicce) taş atıncaya kadar sürekli tekrar edin:";

"hajj_step1_talbiyah_arabic" = "لَبَّيْكَ اللَّهُمَّ لَبَّيْكَ، لَبَّيْكَ لاَ شَرِيكَ لَكَ لَبَّيْكَ، إِنَّ الْحَمْدَ، وَالنِّعْمَةَ، لَكَ وَالْمُلْكَ، لاَ شَرِيكَ لَكَ";
